# Configuration
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
CONFIG_DIR="$SCRIPT_DIR/config"
DOCS_DIR="$SCRIPT_DIR/docs"
CACHE_DIR="$SCRIPT_DIR/cache"
SCRIPTS_DIR="$SCRIPT_DIR/scripts"

# Fichiers de documentation - Utiliser la nouvelle version 1.14.1
DOC_ULTRA="$DOCS_DIR/DSFR_v1.14.1_ULTRA_COMPLETE_20250905_1423.md"
# Fallback sur l'ancienne si la nouvelle n'existe pas
if [ ! -f "$DOC_ULTRA" ]; then
    DOC_ULTRA="$DOCS_DIR/DSFR_v1.14_PLAYBOOK_ULTRA_COMPLET.md"
fi
DOC_EXHAUSTIF="$DOC_ULTRA"
DOC_URLS="$DOCS_DIR/DSFR_v1.14_ALL_URLs_Complete.md"
CONTEXT_FILE="$CONFIG_DIR/context.md"

# Couleurs pour l'interface
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Créer les dossiers si nécessaire
mkdir -p "$CACHE_DIR" "$CONFIG_DIR" "$DOCS_DIR"

# Détection du CLI disponible
detect_cli() {
    if command -v claude &> /dev/null; then
        echo "claude"
    elif command -v gemini &> /dev/null; then
        echo "gemini"
    else
        echo "none"
    fi
}

