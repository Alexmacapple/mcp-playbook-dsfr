}

# Stats
show_stats() {
    echo -e "${BLUE}═══════════════════════════════════════════════${NC}"
    echo -e "${GREEN}           Statistiques DSFR Agent             ${NC}"
    echo -e "${BLUE}═══════════════════════════════════════════════${NC}"
    echo
    echo -e "${YELLOW}Documentation:${NC}"
    [ -f "$DOC_ULTRA" ] && echo -e "  • ULTRA: $(du -h "$DOC_ULTRA" | cut -f1)"
    [ -f "$DOC_EXHAUSTIF" ] && echo -e "  • Exhaustif: $(du -h "$DOC_EXHAUSTIF" | cut -f1)"
    echo
    echo -e "${YELLOW}Cache:${NC}"
    if [ -d "$CACHE_DIR" ]; then
        echo -e "  • Fichiers en cache: $(ls -1 "$CACHE_DIR" 2>/dev/null | wc -l)"
        echo -e "  • Taille du cache: $(du -sh "$CACHE_DIR" 2>/dev/null | cut -f1)"
    fi
    echo
    echo -e "${YELLOW}CLI disponible:${NC} $(detect_cli)"
    echo -e "${YELLOW}Chemin:${NC} $SCRIPT_DIR"
}

# Main
main() {
    case "${1:-}" in
        -h|--help)
            show_help
            ;;
        -i|--interactive)
            interactive_mode
            ;;
        -c|--component)
            search_component "$2"
            ;;
        -l|--list)
            list_components
            ;;
        -e|--example)
            generate_component "${2:-button}"
            ;;
        --init)
            init_project "$2"
            ;;
        --clear-cache)
            rm -rf "$CACHE_DIR"/*
            echo -e "${GREEN}✓ Cache vidé${NC}"
            ;;
        --stats)
            show_stats
            ;;
        *)
            if [ -n "${1:-}" ]; then
                query_llm "$*"
            else
                show_help
            fi
            ;;
    esac
}

# Lancement
main "$@"