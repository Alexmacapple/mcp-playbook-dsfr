║           DSFR Agent v1.0 - Guide d'utilisation       ║
╚═══════════════════════════════════════════════════════╝${NC}

${GREEN}Usage:${NC}
  ./dsfr-agent [OPTIONS] "votre question"

${GREEN}Options:${NC}
  ${YELLOW}-h, --help${NC}           Afficher cette aide
  ${YELLOW}-i, --interactive${NC}    Mode interactif avec menu
  ${YELLOW}-c, --component${NC}      Rechercher un composant spécifique
  ${YELLOW}-l, --list${NC}           Lister tous les composants
  ${YELLOW}-e, --example${NC}        Afficher un exemple de code
  ${YELLOW}--init PROJECT${NC}       Initialiser un nouveau projet DSFR
  ${YELLOW}--clear-cache${NC}        Vider le cache des réponses
  ${YELLOW}--use-full${NC}           Utiliser la doc complète (4.2MB)
