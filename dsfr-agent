${BLUE}Documentation:${NC} $DOCS_DIR
${BLUE}Support:${NC} Voir SHARE_WITH_TEAM.md

EOF
}

# Mode interactif
interactive_mode() {
    clear
    echo -e "${BLUE}╔═══════════════════════════════════════════════════════╗"
    echo -e "║         🇫🇷 DSFR Agent - Mode Interactif 🇫🇷          ║"
    echo -e "╚═══════════════════════════════════════════════════════╝${NC}"
    echo
    echo -e "${GREEN}Que souhaitez-vous faire ?${NC}"
    echo
    echo "1) 🔍 Rechercher un composant"
    echo "2) 💻 Générer du code HTML"
    echo "3) 📚 Voir la documentation d'un composant"
    echo "4) 🎨 Créer un template complet"
    echo "5) ♿ Vérifier l'accessibilité"
    echo "6) 📋 Lister tous les composants"
    echo "7) 🚀 Initialiser un nouveau projet"
    echo "8) ❓ Poser une question libre"
    echo "9) 🚪 Quitter"
    echo
    read -p "Votre choix [1-9]: " choice
    
    case $choice in
        1)
            read -p "Nom du composant: " comp
            search_component "$comp"
            ;;
        2)
            read -p "Quel composant voulez-vous générer ? " comp
            generate_component "$comp"
            ;;
        3)
            read -p "Nom du composant: " comp
            show_component_doc "$comp"
            ;;
        4)
            generate_template
            ;;
        5)
            read -p "Collez votre code HTML: " code
            check_accessibility "$code"
            ;;
        6)
            list_components
            ;;
        7)
            read -p "Nom du projet: " project
            init_project "$project"
            ;;
        8)
            read -p "Votre question: " question
            query_llm "$question"
            ;;
        9)
            echo -e "${GREEN}Au revoir !${NC}"
            exit 0
            ;;
        *)
            echo -e "${RED}Option invalide${NC}"
            sleep 2
            interactive_mode
            ;;
    esac
    
    echo
    read -p "Appuyez sur Entrée pour continuer..."
    interactive_mode
}

# Rechercher un composant
search_component() {
    local component="$1"
    echo -e "${BLUE}Recherche du composant: $component...${NC}"
    
    # Vérifier le cache d'abord
    local cache_file="${CACHE_DIR}/component_${component}.md"
    if [ -f "$cache_file" ]; then
        echo -e "${GREEN}✓ Trouvé dans le cache${NC}"
        cat "$cache_file"
        return
    fi
    
    # Rechercher dans la documentation
    if [ -f "$DOC_EXHAUSTIF" ]; then
        grep -A 50 -i "## .*$component" "$DOC_EXHAUSTIF" | tee "$cache_file"
    else
        echo -e "${RED}Documentation non trouvée${NC}"
    fi
}

# Générer un composant
generate_component() {
    local component="$1"
    local cli=$(detect_cli)
    
    echo -e "${BLUE}Génération du composant: $component...${NC}"
    
    # Toujours utiliser le fallback pour l'instant
    echo -e "${YELLOW}Génération depuis la documentation v1.14.1:${NC}"
    echo
    
    # Chercher le composant dans la nouvelle doc
    local component_upper=$(echo "$component" | tr '[:lower:]' '[:upper:]')
    if grep -q "## 🔹 $component_upper" "$DOC_EXHAUSTIF" 2>/dev/null; then
        # Extraire la section du composant avec le template HTML
        sed -n "/## 🔹 $component_upper/,/^## 🔹/p" "$DOC_EXHAUSTIF" | \
        sed -n '/```html/,/```/p' | \
        sed '1d;$d' | head -20
        echo
        echo -e "${GREEN}✓ Code généré depuis la documentation v1.14.1${NC}"
    else
        # Recherche plus flexible
        echo -e "${YELLOW}Exemple de code pour $component:${NC}"
        echo
        # Exemple basique pour les composants courants
        case "$component" in
            button)
                cat << 'EOF'
<button class="fr-btn">
    Label du bouton
</button>

<!-- Bouton primaire avec icône -->
<button class="fr-btn fr-btn--icon-left fr-icon-save-line">
    Enregistrer
</button>

<!-- Bouton secondaire -->
<button class="fr-btn fr-btn--secondary">
    Action secondaire
</button>
EOF
                ;;
            input)
                cat << 'EOF'
<div class="fr-input-group">
    <label class="fr-label" for="text-input">
        Label du champ
        <span class="fr-hint-text">Texte d'aide</span>
    </label>
    <input class="fr-input" type="text" id="text-input" name="text-input">
</div>
EOF
                ;;
            *)
                grep -A 10 -i "$component" "$DOC_EXHAUSTIF" | head -15
                ;;
        esac
    fi
}

# Requête LLM générique
query_llm() {
    local query="$1"
    local cli=$(detect_cli)
    local doc_file="$DOC_EXHAUSTIF"
    
    # Utiliser la doc complète si demandé
    if [[ "$*" == *"--use-full"* ]]; then
        doc_file="$DOC_ULTRA"
        echo -e "${YELLOW}Utilisation de la documentation complète (4.2MB)${NC}"
    fi
    
    case $cli in
        claude)
            claude --context "$CONTEXT_FILE" \
                   --file "$doc_file" \
                   "$query"
            ;;
        gemini)
            gemini generate \
                   --context-file "$doc_file" \
                   --temperature 0.3 \
                   "Expert DSFR v1.14: $query"
            ;;
        none)
            echo -e "${RED}❌ Aucun CLI trouvé (claude ou gemini)${NC}"
            echo -e "${YELLOW}Installez Claude CLI ou Gemini CLI pour utiliser cette fonction${NC}"
            echo
            echo "Installation Claude CLI:"
            echo "  pip install anthropic-cli"
            echo
            echo "Installation Gemini CLI:"
            echo "  pip install google-generativeai-cli"
            ;;
    esac
}

