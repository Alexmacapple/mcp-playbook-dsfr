# Configuration MCP DSFR Server
# Copier ce fichier en .env et adapter les valeurs

# Environnement (development, staging, production)
ENV=development

# Niveau de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Chemins (optionnel, utilise les valeurs par défaut si non défini)
# GABARITS_DIR=/custom/path/to/gabarits
# DATA_DIR=/custom/path/to/data

# Performance
MAX_CACHE_SIZE=256
MAX_COMPONENTS_IN_LIST=20
MAX_HTML_SIZE=1000000

# Validation RGAA
DEFAULT_RGAA_LEVEL=AA
VALIDATE_ON_GENERATE=false

# Sécurité
ENABLE_HTML_SANITIZATION=true
MAX_REQUEST_SIZE=5000000
RATE_LIMIT_PER_MINUTE=60

# Monitoring (optionnel)
ENABLE_METRICS=false
METRICS_PORT=9090

# Debug
DEBUG=false
PRETTY_LOGS=true